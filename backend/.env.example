# Gemini API Key — get from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key

# Google Cloud (for Firestore)
GOOGLE_CLOUD_PROJECT=your-project-id
GOOGLE_APPLICATION_CREDENTIALS=/app/service-account.json

# Google Maps API Key
GOOGLE_MAPS_API_KEY=your-maps-api-key

# Serper API Key — 2500 free queries/month
# Get key: https://serper.dev
# Used by: MCP search_server.py (via MCP protocol) + direct fallback
SERPER_API_KEY=your-serper-key

# Google Calendar service account JSON path (inside container)
GOOGLE_CALENDAR_CREDENTIALS_JSON=/app/service-account.json

# MCP Calendar server URL (auto-configured in docker-compose)
CALENDAR_MCP_URL=http://calendar-mcp:8003/mcp

# Optional
FIRESTORE_COLLECTION_PREFIX=
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]
ENABLE_WEB_SEARCH=true
